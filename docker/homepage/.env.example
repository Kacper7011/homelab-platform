# AdGuard Home
HOMEPAGE_VAR_ADGUARD_USERNAME=admin
HOMEPAGE_VAR_ADGUARD_PASSWORD=your_adguard_password

# Grafana
HOMEPAGE_VAR_GRAFANA_USERNAME=admin
HOMEPAGE_VAR_GRAFANA_PASSWORD=your_grafana_password

# Proxmox - API Token (format: user@realm!tokenid)
# Create via: Datacenter > Permissions > API Tokens
HOMEPAGE_VAR_PROXMOX_TOKEN_ID=user@pam!homepage
HOMEPAGE_VAR_PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Seafile
HOMEPAGE_VAR_SEAFILE_USERNAME=your@email.com
HOMEPAGE_VAR_SEAFILE_PASSWORD=your_seafile_password

# Syncthing - API Key
# Find via: Syncthing UI > Actions > Settings > GUI > API Key
HOMEPAGE_VAR_SYNCTHING_API_KEY=your_syncthing_api_key

# Forgejo - API Token
# Create via: Forgejo > Settings > Applications > Generate New Token
HOMEPAGE_VAR_FORGEJO_API_TOKEN=your_forgejo_api_token

# Navidrome
HOMEPAGE_VAR_NAVIDROME_USERNAME=admin
HOMEPAGE_VAR_NAVIDROME_PASSWORD=your_navidrome_password
