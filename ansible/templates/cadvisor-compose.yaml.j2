services:
  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ image_version }}
    container_name: cadvisor
    restart: unless-stopped
    privileged: true
    ports:
      - "{{ port }}:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker:/var/lib/docker:ro
      - /dev/disk:/dev/disk:ro